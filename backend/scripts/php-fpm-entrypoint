#!/bin/sh
set -e

echo "Starting PHP-FPM entrypoint..."

# Ensure required directories exist (idempotent)
mkdir -p storage/framework/{cache,sessions,views} bootstrap/cache

# Fix permissions only if needed (avoid recursive chown every start)
if [ "$(stat -c '%U' storage)" != "www-data" ]; then
  echo "Fixing storage and cache permissions..."
  chown -R www-data:www-data storage bootstrap/cache
  chmod -R 775 storage bootstrap/cache
fi

# Optionally cache config/routes/views in production
# (safe because image already contains app + vendor)
if [ "$APP_ENV" = "production" ]; then
  echo "Optimizing Laravel caches..."
  php artisan config:clear || true
  php artisan config:cache || true
  php artisan route:cache || true
  php artisan view:clear || true
fi

# Hand over to the main container command
echo "Launching PHP-FPM..."
exec "$@"
