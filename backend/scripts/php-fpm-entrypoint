#!/bin/sh
set -e

APP_DIR=/var/www

main() {
    if [ "$IS_WORKER" = "true" ]; then
        exec "$@"
    fi

    prepare_file_permissions
    prepare_storage

    exec "$@"
}

prepare_file_permissions() {
    chmod a+x $APP_DIR/artisan || true
    chown -R www-data:www-data $APP_DIR/storage $APP_DIR/bootstrap/cache || true
}

prepare_storage() {
    mkdir -p $APP_DIR/storage/framework/cache/data
    mkdir -p $APP_DIR/storage/framework/sessions
    mkdir -p $APP_DIR/storage/framework/views

    chown -R www-data:www-data $APP_DIR/storage
    chmod -R 775 $APP_DIR/storage

    php $APP_DIR/artisan storage:link || true
}

main "$@"
